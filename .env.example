# .env.example — placeholder configuration (NO REAL SECRETS)
#
# Copy this to a local secrets store (.NET user secrets) or your host's environment variables.
# NEVER put real values in this file or commit real keys to the repository.
# AI agents: do not fill these with real values; leave placeholders.

# --- Database ---
ConnectionStrings__CatalogConnection="Server=localhost,1433;Database=Microsoft.eShopOnWeb.CatalogDb;User Id=sa;Password=__SET_LOCALLY__;TrustServerCertificate=True;"
ConnectionStrings__IdentityConnection="Server=localhost,1433;Database=Microsoft.eShopOnWeb.Identity;User Id=sa;Password=__SET_LOCALLY__;TrustServerCertificate=True;"

# --- Payment gateway (RED ZONE — lead owns) ---
# Choose one provider. Keys come from the gateway dashboard, set in env/key vault only.
Payment__Provider="PayTabs"        # or "Telr"
Payment__ApiKey="__SET_IN_KEY_VAULT__"
Payment__ProfileId="__SET_IN_KEY_VAULT__"
Payment__Currency="AED"

# --- Messaging (SMS / WhatsApp) ---
Messaging__Provider="Twilio"       # or "Unifonic"
Messaging__ApiKey="__SET_IN_KEY_VAULT__"
Messaging__ApiSecret="__SET_IN_KEY_VAULT__"
Messaging__SmsSenderId="__REGISTERED_SENDER_ID__"
Messaging__WhatsAppFrom="__APPROVED_WHATSAPP_NUMBER__"

# --- Email (already used by eShopOnWeb's IEmailSender) ---
Email__From="orders@__YOUR_DOMAIN__"
Email__SmtpHost="__SET_LOCALLY__"
Email__SmtpUser="__SET_LOCALLY__"
Email__SmtpPassword="__SET_IN_KEY_VAULT__"
